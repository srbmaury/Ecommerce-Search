# Database Configuration
# For Neon PostgreSQL (Production):
# DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# For local development (SQLite):
# DATABASE_URL=sqlite:///data/ecommerce.db

# Or leave empty to use default SQLite:
DATABASE_URL=

# Flask Configuration
FLASK_DEBUG=0

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:5173

# Upstash Redis direct connection URL for RQ/worker
REDIS_URL=

# Resend API key for email sending in production (https://resend.com)
# Takes priority over SMTP when set. Required on cloud hosts that block SMTP (e.g. Render).
RESEND_API_KEY=

# Admin user IDs (comma-separated) for admin endpoint access
ADMIN_USER_IDS=user1,user2,user3

# Shared secret required in X-Admin-Secret header for all admin endpoints
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=

# Flask session signing key — must be a long random string in production
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=